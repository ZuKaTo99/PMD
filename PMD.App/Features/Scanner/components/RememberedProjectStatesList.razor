@namespace PMD.App.Features.Scanner.Components
@using PMD.App.Domain.ProjectStates


@if (ProjectStates.Count > 0)
{
    <div class="card mb-4">
        <div class="card-header">
            <div class="d-flex flex-column flex-lg-row justify-content-between gap-2">
                <div>
                    <h2 class="h5 mb-1">Gemerkte Projektstände</h2>
                    <div class="text-muted small">
                        Diese Projektstände sind aktuell nur für diese laufende Sitzung gemerkt.
                    </div>
                </div>

                <div>
                    <span class="badge bg-secondary">
                        @ProjectStates.Count gemerkt
                    </span>
                </div>
            </div>
        </div>

        <div class="card-body">
            @if (ProjectStates.Count >= 2)
            {
                <div class="border rounded p-3 mb-4">
                    <div class="mb-3">
                        <h3 class="h6 mb-1">Projektstände vergleichen</h3>
                        <div class="text-muted small">
                            Wähle links den älteren Stand und rechts den neueren Stand aus.
                            Danach kannst du beide Projektstände miteinander vergleichen.
                        </div>
                    </div>

                    <div class="row g-3 align-items-end">
                        <div class="col-md-5">
                            <label class="form-label">Alter Stand</label>
                            <select class="form-select form-select-sm"
                                    value="@FormatProjectStateId(SelectedOldProjectStateId)"
                                    @onchange="OnSelectedOldProjectStateChanged">
                                <option value="">Bitte auswählen</option>

                                @foreach (var projectState in ProjectStates)
                                {
                                    <option value="@projectState.Id">
                                        @BuildProjectStateOptionText(projectState)
                                    </option>
                                }
                            </select>

                            <div class="form-text">
                                Der Stand, mit dem verglichen wird.
                            </div>
                        </div>

                        <div class="col-md-5">
                            <label class="form-label">Neuer Stand</label>
                            <select class="form-select form-select-sm"
                                    value="@FormatProjectStateId(SelectedNewProjectStateId)"
                                    @onchange="OnSelectedNewProjectStateChanged">
                                <option value="">Bitte auswählen</option>

                                @foreach (var projectState in ProjectStates)
                                {
                                    <option value="@projectState.Id">
                                        @BuildProjectStateOptionText(projectState)
                                    </option>
                                }
                            </select>

                            <div class="form-text">
                                Der Stand, der geprüft werden soll.
                            </div>
                        </div>

                        <div class="col-md-2 d-grid">
                            <button class="btn btn-primary btn-sm"
                                    disabled="@(!CanCompareSelectedProjectStates)"
                                    @onclick="OnCompareSelectedProjectStates">
                                Auswahl vergleichen
                            </button>
                        </div>
                    </div>

                    @if (HasSelectedSameProjectState)
                    {
                        <div class="alert alert-warning py-2 mt-3 mb-0">
                            Bitte wählen Sie zwei unterschiedliche Projektstände aus.
                        </div>
                    }
                    else if (HasSelectedDifferentProjectFolders)
                    {
                        <div class="alert alert-danger py-2 mt-3 mb-0">
                            Bitte wählen Sie zwei Projektstände aus demselben Projektordner aus.
                        </div>
                    }
                </div>
            }

            <div class="d-flex flex-column flex-lg-row justify-content-between gap-2 mb-2">
                <h3 class="h6 mb-0">Aktuell gemerkte Stände</h3>

                <div class="text-muted small">
                    Die Stände verschwinden, wenn die App neu gestartet wird.
                </div>
            </div>

            <div class="table-responsive mb-3">
                <table class="table table-sm table-striped align-middle">
                    <thead>
                        <tr>
                            <th>Stand</th>
                            <th>Projekt</th>
                            <th>Projektordner</th>
                            <th>Erstellt am</th>
                            <th>Geprüft am</th>
                            <th>Dateien</th>
                            <th>Größe</th>
                        </tr>
                    </thead>

                    <tbody>
                        @for (var i = 0; i < ProjectStates.Count; i++)
                        {
                            var projectState = ProjectStates[i];
                            var projectStateNumber = ProjectStates.Count - i;

                            <tr>
                                <td>@ScannerDisplayFormatter.FormatProjectStateLabel(projectStateNumber)</td>>
                                <td>@projectState.ProjectName</td>
                                <td>
                                    <code>@projectState.RootPath</code>
                                </td>
                                <td>@projectState.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                                <td>@projectState.ScannedAt.ToString("dd.MM.yyyy HH:mm")</td>
                                <td>@projectState.FileCount</td>
                                <td>@ScannerDisplayFormatter.FormatFileSize(projectState.TotalSizeInBytes)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="d-flex flex-column flex-md-row gap-2">
                <button class="btn btn-outline-primary"
                        disabled="@(ProjectStates.Count < 2)"
                        @onclick="OnCompareLatestProjectStates">
                    Letzte 2 Projektstände vergleichen
                </button>

                <button class="btn btn-outline-danger"
                        @onclick="OnClearRememberedProjectStates">
                    Gemerkte Stände leeren
                </button>
            </div>
        </div>
    </div>
}
