@namespace PMD.App.Features.Scanner.Components
@using Microsoft.AspNetCore.Components
@using PMD.App.Domain.ProjectStates

@if (PreparedProjectState is not null)
{
    <div class="card mb-4">
        <div class="card-header">
            <div class="d-flex flex-column flex-lg-row justify-content-between gap-2">
                <div>
                    <h2 class="h5 mb-1">Projektstand vorbereitet</h2>
                    <div class="text-muted small">
                        Aus der letzten Projektprüfung wurde ein Projektstand vorbereitet.
                    </div>
                </div>

                <div>
                    @if (IsAlreadyRemembered)
                    {
                        <span class="badge bg-success">
                            Bereits gemerkt
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">
                            Noch nicht gemerkt
                        </span>
                    }
                </div>
            </div>
        </div>

        <div class="card-body">
            <div class="alert alert-light border mb-4">
                Dieser Projektstand ist aktuell nur vorbereitet. Du kannst ihn für diese laufende Sitzung merken,
                um ihn später mit einem anderen Projektstand zu vergleichen.
            </div>

            <div class="border rounded p-3 mb-4">
                <div class="text-muted small mb-1">Projekt</div>
                <div class="fw-semibold">@PreparedProjectState.ProjectName</div>

                <div class="text-muted small mt-3 mb-1">Projektordner</div>
                <code class="small">@PreparedProjectState.RootPath</code>
            </div>

            <div class="row g-3 mb-4">
                <div class="col-6 col-md-4 col-lg-3">
                    <div class="border rounded p-3 h-100">
                        <div class="text-muted small">Dateien</div>
                        <div class="fs-4 fw-semibold">@PreparedProjectState.FileCount</div>
                    </div>
                </div>

                <div class="col-6 col-md-4 col-lg-3">
                    <div class="border rounded p-3 h-100">
                        <div class="text-muted small">Gesamtgröße</div>
                        <div class="fs-5 fw-semibold">
                            @ScannerDisplayFormatter.FormatFileSize(PreparedProjectState.TotalSizeInBytes)
                        </div>
                    </div>
                </div>

                <div class="col-12 col-md-4 col-lg-3">
                    <div class="border rounded p-3 h-100">
                        <div class="text-muted small">Erstellt am</div>
                        <div class="fw-semibold">
                            @PreparedProjectState.CreatedAt.ToString("dd.MM.yyyy HH:mm:ss")
                        </div>
                    </div>
                </div>

                <div class="col-12 col-md-4 col-lg-3">
                    <div class="border rounded p-3 h-100">
                        <div class="text-muted small">Status</div>
                        <div class="fw-semibold">
                            @(IsAlreadyRemembered ? "Für Vergleich bereit" : "Kann gemerkt werden")
                        </div>
                    </div>
                </div>
            </div>

            @if (IsAlreadyRemembered)
            {
                <div class="alert alert-success mb-0">
                    Dieser Projektstand wurde bereits gemerkt und kann für einen Vergleich ausgewählt werden.
                </div>
            }
            else
            {
                <div class="d-flex flex-column flex-md-row align-items-md-center gap-2">
                    <button class="btn btn-primary"
                            @onclick="OnRememberProjectState">
                        Projektstand merken
                    </button>

                    <div class="text-muted small">
                        Der Stand wird nur bis zum Neustart der App gemerkt.
                    </div>
                </div>
            }
        </div>
    </div>
}

@code {
    [Parameter]
    public ProjectState? PreparedProjectState { get; set; }

    [Parameter]
    public bool IsAlreadyRemembered { get; set; }

    [Parameter]
    public EventCallback OnRememberProjectState { get; set; }
}