@namespace PMD.App.Features.Scanner.Components
@using Microsoft.AspNetCore.Components
@using PMD.App.Domain.Scanner
@using System.Linq

@if (Files.Count > 0)
{
    <div class="card mb-4">
        <div class="card-header">
            <div class="d-flex flex-column flex-lg-row justify-content-between gap-2">
                <div>
                    <h2 class="h5 mb-1">Gefundene Dateien</h2>
                    <div class="text-muted small">
                        Diese Dateien wurden bei der Projektprüfung gefunden.
                    </div>
                </div>

                <div>
                    <span class="badge bg-secondary">
                        @Files.Count Dateien
                    </span>
                </div>
            </div>
        </div>

        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <div class="text-muted small">
                    Angezeigt: @DisplayedFileCount von @Files.Count Dateien
                </div>

                @if (HiddenFileCount > 0)
                {
                    <span class="badge bg-secondary">
                        +@HiddenFileCount weitere
                    </span>
                }
            </div>

            <div class="table-responsive">
                <table class="table table-sm table-striped table-hover align-middle mb-2">
                    <thead>
                        <tr>
                            <th>Datei</th>
                            <th>Endung</th>
                            <th>Größe</th>
                            <th>Geändert am</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (ProjectFileEntry file in Files.Take(FileLimit))
                        {
                            <tr>
                                <td>
                                    <code class="small">@file.RelativePath</code>
                                </td>

                                <td>
                                    <span class="badge bg-light text-dark border">
                                        @ScannerDisplayFormatter.FormatExtension(file.Extension)
                                    </span>
                                </td>

                                <td>@ScannerDisplayFormatter.FormatFileSize(file.SizeInBytes)</td>
                                <td>@file.LastChangedAt.ToString("dd.MM.yyyy HH:mm")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (HiddenFileCount > 0)
            {
                <p class="text-muted small mb-0">
                    Es werden nur die ersten @FileLimit Dateien angezeigt.
                </p>
            }
        </div>
    </div>
}

@code {
    [Parameter]
    public IReadOnlyList<ProjectFileEntry> Files { get; set; } = Array.Empty<ProjectFileEntry>();

    [Parameter]
    public int FileLimit { get; set; } = 25;

    private int DisplayedFileCount =>
        Math.Min(Files.Count, FileLimit);

    private int HiddenFileCount =>
        Math.Max(0, Files.Count - FileLimit);
}