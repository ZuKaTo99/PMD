@namespace PMD.App.Features.Scanner.Components
@using Microsoft.AspNetCore.Components
@using PMD.App.Domain.Scanner

@if (Files.Count > 0)
{
    <div class="card mb-4">
        <div class="card-body">
            <h5 class="card-title">Gefundene Dateien</h5>

            <p class="text-muted">
                Es werden die ersten @FileLimit Dateien angezeigt.
            </p>

            <div class="table-responsive">
                <table class="table table-sm table-striped align-middle">
                    <thead>
                        <tr>
                            <th>Datei</th>
                            <th>Endung</th>
                            <th>Größe</th>
                            <th>Geändert am</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var file in Files.Take(FileLimit))
                        {
                            <tr>
                                <td>
                                    <code>@file.RelativePath</code>
                                </td>
                                <td>@ScannerDisplayFormatter.FormatExtension(file.Extension)</td>
                                <td>@ScannerDisplayFormatter.FormatFileSize(file.SizeInBytes)</td>
                                <td>@file.LastChangedAt.ToString("dd.MM.yyyy HH:mm")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (Files.Count > FileLimit)
            {
                <p class="text-muted mb-0">
                    Es gibt weitere Dateien, die hier nicht angezeigt werden.
                </p>
            }
        </div>
    </div>
}

@code {
    [Parameter]
    public IReadOnlyList<ProjectFileEntry> Files { get; set; } = Array.Empty<ProjectFileEntry>();

    [Parameter]
    public int FileLimit { get; set; } = 25;
}