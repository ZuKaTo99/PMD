@namespace PMD.App.Features.Scanner.Components
@using Microsoft.AspNetCore.Components

<div class="card mb-4">
    <div class="card-header">
        <div class="d-flex flex-column flex-lg-row justify-content-between gap-2">
            <div>
                <h2 class="h5 mb-1">Projektordner prüfen</h2>
                <div class="text-muted small">
                    Wähle einen Projektordner aus oder trage den vollständigen Pfad manuell ein.
                </div>
            </div>

            <div>
                <span class="badge bg-secondary">
                    Projektprüfung
                </span>
            </div>
        </div>
    </div>

    <div class="card-body">
        <div class="alert alert-light border mb-4">
            PMD liest den ausgewählten Projektordner ein und zeigt dir danach Dateien,
            Dateitypen, größte Dateien, Hinweise und übersprungene Ordner an.
        </div>

        <div class="mb-3">
            <label class="form-label" for="folder-path">Projektordner</label>

            <input id="folder-path"
                   class="form-control"
                   placeholder="C:\Pfad\Zum\Projektordner"
                   value="@FolderPath"
                   @oninput="OnFolderPathInputChanged" />

            <div class="form-text">
                Du kannst den Ordner über den Button auswählen oder den Pfad direkt einfügen.
            </div>
        </div>

        <div class="d-flex flex-column flex-md-row gap-2">
            <button class="btn btn-outline-secondary"
                    @onclick="OnPickFolder">
                Ordner auswählen
            </button>

            <button class="btn btn-primary"
                    @onclick="OnScanProjectFolder">
                Projekt prüfen
            </button>
        </div>

        @if (!string.IsNullOrWhiteSpace(FolderPath))
        {
            <div class="text-muted small mt-3">
                Aktueller Pfad:
                <code>@FolderPath</code>
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(ErrorMessage))
        {
            <div class="alert alert-danger mt-3 mb-0">
                @ErrorMessage
            </div>
        }
    </div>
</div>

@code {
    [Parameter]
    public string FolderPath { get; set; } = string.Empty;

    [Parameter]
    public EventCallback<string> FolderPathChanged { get; set; }

    [Parameter]
    public string? ErrorMessage { get; set; }

    [Parameter]
    public EventCallback OnPickFolder { get; set; }

    [Parameter]
    public EventCallback OnScanProjectFolder { get; set; }

    private async Task OnFolderPathInputChanged(ChangeEventArgs e)
    {
        FolderPath = e.Value?.ToString() ?? string.Empty;

        await FolderPathChanged.InvokeAsync(FolderPath);
    }
}