@namespace PMD.App.Features.Scanner.Components
@using Microsoft.AspNetCore.Components
@using PMD.App.Domain.Scanner

@if (Files.Count > 0)
{
    <div class="card mb-4">
        <div class="card-body">
            <h5 class="card-title">Größte Dateien</h5>

            <div class="table-responsive">
                <table class="table table-sm align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Datei</th>
                            <th>Größe</th>
                            <th>Geändert</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var file in GetLargestFiles())
                        {
                            <tr>
                                <td>@file.RelativePath</td>
                                <td>@ScannerDisplayFormatter.FormatFileSize(file.SizeInBytes)</td>
                                <td>@file.LastChangedAt.ToString("dd.MM.yyyy HH:mm:ss")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <p class="text-muted small mt-3 mb-0">
                Es werden die @FileLimit größten Dateien im geprüften Projektordner angezeigt.
            </p>
        </div>
    </div>
}

@code {
    [Parameter]
    public IReadOnlyList<ProjectFileEntry> Files { get; set; } = Array.Empty<ProjectFileEntry>();

    [Parameter]
    public int FileLimit { get; set; } = 10;

    private IEnumerable<ProjectFileEntry> GetLargestFiles()
    {
        return Files
            .OrderByDescending(file => file.SizeInBytes)
            .ThenBy(file => file.RelativePath)
            .Take(FileLimit);
    }
}