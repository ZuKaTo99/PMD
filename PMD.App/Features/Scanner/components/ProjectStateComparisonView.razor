@namespace PMD.App.Features.Scanner.Components
@using PMD.App.Domain.ProjectStates

@if (ComparisonResult is not null)
{
    <div class="card mb-4">
        <div class="card-header">
            <div class="d-flex flex-column flex-lg-row justify-content-between gap-2">
                <div>
                    <h2 class="h5 mb-1">Vergleichsergebnis</h2>
                    <div class="text-muted small">
                        Hier siehst du, was sich zwischen zwei Projektständen geändert hat.
                    </div>
                </div>

                <div>
                    <span class="badge bg-secondary">
                        Änderungen gesamt: @ComparisonResult.TotalChangeCount
                    </span>
                </div>
            </div>
        </div>

        <div class="card-body">
            @if (OldProjectState is not null && NewProjectState is not null)
            {
                <div class="alert alert-info mb-4">
                    <div class="fw-semibold mb-2">Verglichen wird:</div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="border rounded bg-white p-3 h-100">
                                <div class="text-muted small mb-1">Alter Stand</div>
                                <div class="fw-semibold">@OldProjectState.ProjectName</div>
                                <div class="small">@FormatDateTime(OldProjectState.CreatedAt)</div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="border rounded bg-white p-3 h-100">
                                <div class="text-muted small mb-1">Neuer Stand</div>
                                <div class="fw-semibold">@NewProjectState.ProjectName</div>
                                <div class="small">@FormatDateTime(NewProjectState.CreatedAt)</div>
                            </div>
                        </div>
                    </div>
                </div>
            }

            <div class="row g-3 mb-4">
                <div class="col-6 col-md-4 col-lg-2">
                    <div class="border rounded p-3 h-100">
                        <div class="text-muted small">Neue Dateien</div>
                        <div class="fs-4 fw-semibold">@ComparisonResult.NewFileCount</div>
                    </div>
                </div>

                <div class="col-6 col-md-4 col-lg-2">
                    <div class="border rounded p-3 h-100">
                        <div class="text-muted small">Geänderte Dateien</div>
                        <div class="fs-4 fw-semibold">@ComparisonResult.ChangedFileCount</div>
                    </div>
                </div>

                <div class="col-6 col-md-4 col-lg-2">
                    <div class="border rounded p-3 h-100">
                        <div class="text-muted small">Gelöschte Dateien</div>
                        <div class="fs-4 fw-semibold">@ComparisonResult.DeletedFileCount</div>
                    </div>
                </div>

                <div class="col-6 col-md-4 col-lg-2">
                    <div class="border rounded p-3 h-100">
                        <div class="text-muted small">Unverändert</div>
                        <div class="fs-4 fw-semibold">@ComparisonResult.UnchangedFileCount</div>
                    </div>
                </div>

                <div class="col-6 col-md-4 col-lg-2">
                    <div class="border rounded p-3 h-100">
                        <div class="text-muted small">Änderungen gesamt</div>
                        <div class="fs-4 fw-semibold">@ComparisonResult.TotalChangeCount</div>
                    </div>
                </div>
            </div>

            @if (ComparisonResult.TotalChangeCount == 0)
            {
                <div class="alert alert-success mb-0">
                    Keine Änderungen gefunden. Die beiden Projektstände sehen aktuell gleich aus.
                </div>
            }
            else
            {
                <div class="alert alert-light border mb-4">
                    Es wurden Änderungen gefunden. Die Listen darunter zeigen dir, welche Dateien neu,
                    geändert oder gelöscht wurden.
                </div>
            }

            @if (ComparisonResult.NewFilePaths.Count > 0)
            {
                <div class="border rounded p-3 mb-3">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h3 class="h6 mb-0">Neue Dateien</h3>
                        <span class="badge bg-secondary">@ComparisonResult.NewFileCount</span>
                    </div>

                    <ProjectFilePathList FilePaths="@ComparisonResult.NewFilePaths"
                                         FileLimit="@FileLimit" />
                </div>
            }

            @if (ComparisonResult.ChangedFiles.Count > 0)
            {
                <div class="border rounded p-3 mb-3">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h3 class="h6 mb-0">Geänderte Dateien</h3>
                        <span class="badge bg-secondary">@ComparisonResult.ChangedFileCount</span>
                    </div>

                    <div class="text-muted small mb-2">
                        Diese Dateien gab es in beiden Projektständen, aber Größe oder Änderungszeit haben sich geändert.
                    </div>

                    <ChangedProjectFilesTable ChangedFiles="@ComparisonResult.ChangedFiles"
                                              FileLimit="@FileLimit" />
                </div>
            }

            @if (ComparisonResult.DeletedFilePaths.Count > 0)
            {
                <div class="border rounded p-3 mb-0">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h3 class="h6 mb-0">Gelöschte Dateien</h3>
                        <span class="badge bg-secondary">@ComparisonResult.DeletedFileCount</span>
                    </div>

                    <ProjectFilePathList FilePaths="@ComparisonResult.DeletedFilePaths"
                                         FileLimit="@FileLimit" />
                </div>
            }
        </div>
    </div>
}

@code {
    [Parameter]
    public ProjectStateComparisonResult? ComparisonResult { get; set; }

    [Parameter]
    public ProjectState? OldProjectState { get; set; }

    [Parameter]
    public ProjectState? NewProjectState { get; set; }

    [Parameter]
    public int FileLimit { get; set; } = 20;

    private static string FormatDateTime(DateTime value)
    {
        return value.ToString("dd.MM.yyyy HH:mm:ss");
    }
}