@page "/projektpruefung"
@using Microsoft.AspNetCore.Components.Web
@using CommunityToolkit.Maui.Storage
@using PMD.App.Application.ProjectStates
@using PMD.App.Domain.ProjectStates
@using PMD.App.Features.Scanner.Components
@inject IProjectFolderScanner ProjectFolderScanner
@inject IFolderPicker FolderPicker
@inject IProjectStateMemoryStore ProjectStateMemoryStore


<PageTitle>PMD - Projektprüfung</PageTitle>

<div class="container-fluid pmd-scanner-page">
    <div class="mb-4">
        <div class="text-muted small mb-1">PMD - Projektprüfung</div>
        <h1>Projektprüfung</h1>
        <p class="text-muted mb-0">
            Hier kannst du einen Projektordner prüfen lassen.
        </p>
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <h5 class="card-title">Projektordner prüfen</h5>

            <p class="card-text">
                Wähle einen Projektordner aus oder trage den vollständigen Pfad manuell ein.
            </p>

            <div class="mb-3">
                <label class="form-label" for="folder-path">Projektordner</label>
                <input id="folder-path"
                       class="form-control"
                       placeholder="C:\Users\sakar.birkan\source\repos\PMD V0.4"
                       @bind="folderPath" />
            </div>

            <div class="d-flex gap-2 flex-wrap">
                <button class="btn btn-outline-secondary" @onclick="PickFolderAsync">
                    Ordner auswählen
                </button>

                <button class="btn btn-primary" @onclick="ScanProjectFolder">
                    Projekt prüfen
                </button>
            </div>

            @if (!string.IsNullOrWhiteSpace(errorMessage))
            {
                <div class="alert alert-danger mt-3 mb-0">
                    @errorMessage
                </div>
            }
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(infoMessage))
    {
        <div class="alert alert-success mt-3 mb-0">
            @infoMessage
        </div>
    }

    @if (scanResult is not null)
    {
        <div class="card mb-4">
            <div class="card-body">
                <h5 class="card-title">Prüfergebnis</h5>

                <dl class="row mb-0">
                    <dt class="col-sm-3">Projektname</dt>
                    <dd class="col-sm-9">@scanResult.ProjectName</dd>

                    <dt class="col-sm-3">Projektordner</dt>
                    <dd class="col-sm-9">@scanResult.RootPath</dd>

                    <dt class="col-sm-3">Geprüft am</dt>
                    <dd class="col-sm-9">@scanResult.ScannedAt.ToString("dd.MM.yyyy HH:mm:ss")</dd>

                    <dt class="col-sm-3">Dateien</dt>
                    <dd class="col-sm-9">@scanResult.FileCount</dd>

                    <dt class="col-sm-3">Geprüfte Ordner</dt>
                    <dd class="col-sm-9">@scanResult.ScannedFolderCount</dd>

                    <dt class="col-sm-3">Angezeigt</dt>
                    <dd class="col-sm-9">
                        @GetDisplayedFileCount() von @scanResult.FileCount Dateien
                    </dd>

                    <dt class="col-sm-3">Gesamtgröße</dt>
                    <dd class="col-sm-9">@FormatFileSize(scanResult.TotalSizeInBytes)</dd>

                    <dt class="col-sm-3">Prüfdauer</dt>
                    <dd class="col-sm-9">@FormatScanDuration(scanResult.ScanDuration)</dd>

                    <dt class="col-sm-3">Übersprungene Ordner</dt>
                    <dd class="col-sm-9">@scanResult.IgnoredFolderCount</dd>

                    <dt class="col-sm-3">Hinweise</dt>
                    <dd class="col-sm-9">@scanResult.WarningCount</dd>
                </dl>
            </div>
        </div>

        @if (preparedProjectState is not null)
        {
            <div class="card mb-4">
                <div class="card-body">
                    <h5 class="card-title">Projektstand vorbereitet</h5>

                    <p class="text-muted">
                        Aus der Projektprüfung wurde ein Projektstand vorbereitet. Er wird noch nicht dauerhaft gespeichert.
                    </p>

                    <dl class="row mb-0">
                        <dt class="col-sm-3">Projektname</dt>
                        <dd class="col-sm-9">@preparedProjectState.ProjectName</dd>

                        <dt class="col-sm-3">Dateien</dt>
                        <dd class="col-sm-9">@preparedProjectState.Files.Count</dd>

                        <dt class="col-sm-3">Erstellt am</dt>
                        <dd class="col-sm-9">@preparedProjectState.CreatedAt.ToString("dd.MM.yyyy HH:mm:ss")</dd>

                        <dt class="col-sm-3">Gesamtgröße</dt>
                        <dd class="col-sm-9">@FormatFileSize(preparedProjectState.TotalSizeInBytes)</dd>
                    </dl>

                    <div class="mt-3">
                        <button class="btn btn-outline-primary"
                                disabled="@IsPreparedProjectStateRemembered()"
                                @onclick="RememberPreparedProjectState">
                            @(IsPreparedProjectStateRemembered() ? "Bereits gemerkt" : "Projektstand merken")
                        </button>
                    </div>
                </div>
            </div>
        }

        @if (RememberedProjectStates.Count > 0)
        {
            <div class="card mb-4">
                <div class="card-body">
                    <h5 class="card-title">Gemerkte Projektstände</h5>

                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Projektname</th>
                                    <th>Erstellt am</th>
                                    <th>Dateien</th>
                                    <th>Gesamtgröße</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var projectState in RememberedProjectStates.Take(5))
                                {
                                    <tr>
                                        <td>@projectState.ProjectName</td>
                                        <td>@projectState.CreatedAt.ToString("dd.MM.yyyy HH:mm:ss")</td>
                                        <td>@projectState.FileCount</td>
                                        <td>@FormatFileSize(projectState.TotalSizeInBytes)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="d-flex gap-2 flex-wrap mt-3">
                        @if (RememberedProjectStates.Count >= 2)
                        {
                            <button class="btn btn-outline-primary" @onclick="CompareLatestProjectStates">
                                Letzte 2 Projektstände vergleichen
                            </button>
                        }

                        <button class="btn btn-outline-danger" @onclick="ClearRememberedProjectStates">
                            Gemerkte Stände leeren
                        </button>
                    </div>

                    @if (RememberedProjectStates.Count > 5)
                    {
                        <p class="text-muted small mt-3 mb-0">
                            Es werden erstmal nur die letzten 5 gemerkten Projektstände angezeigt.
                        </p>
                    }
                </div>
            </div>
        }

        <ProjectStateComparisonView ComparisonResult="comparisonResult"
                                    OldProjectState="comparedOldProjectState"
                                    NewProjectState="comparedNewProjectState"
                                    FileLimit="ComparisonFileLimit" />

        @if (scanResult.WarningCount > 0)
        {
            <div class="card mb-4">
                <div class="card-body">
                    <h5 class="card-title">Hinweise</h5>

                    <ul class="mb-0">
                        @foreach (var warning in scanResult.Warnings.Take(20))
                        {
                            <li>@warning</li>
                        }
                    </ul>

                    @if (scanResult.WarningCount > 20)
                    {
                        <p class="text-muted small mt-3 mb-0">
                            Es werden erstmal nur die ersten 20 Hinweise angezeigt.
                        </p>
                    }
                </div>
            </div>
        }

        @if (scanResult.IgnoredFolderCount > 0)
        {
            <div class="card mb-4">
                <div class="card-body">
                    <h5 class="card-title">Übersprungene Ordner</h5>

                    <ul class="mb-0">
                        @foreach (var folder in scanResult.IgnoredFolders.Take(20))
                        {
                            <li>@folder</li>
                        }
                    </ul>

                    @if (scanResult.IgnoredFolderCount > 20)
                    {
                        <p class="text-muted small mt-3 mb-0">
                            Es werden erstmal nur die ersten 20 übersprungenen Ordner angezeigt.
                        </p>
                    }
                </div>
            </div>
        }

        @if (scanResult.Files.Count > 0)
        {
            <div class="card mb-4">
                <div class="card-body">
                    <h5 class="card-title">Dateitypen</h5>

                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Dateityp</th>
                                    <th>Dateien</th>
                                    <th>Gesamtgröße</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var fileType in GetFileTypeStats())
                                {
                                    <tr>
                                        <td>@fileType.Extension</td>
                                        <td>@fileType.Count</td>
                                        <td>@FormatFileSize(fileType.SizeInBytes)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <p class="text-muted small mt-3 mb-0">
                        Es werden die häufigsten Dateitypen angezeigt.
                    </p>
                </div>
            </div>
        }

        @if (scanResult.Files.Count > 0)
        {
            <div class="card mb-4">
                <div class="card-body">
                    <h5 class="card-title">Größte Dateien</h5>

                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Datei</th>
                                    <th>Größe</th>
                                    <th>Geändert</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var file in GetLargestFiles())
                                {
                                    <tr>
                                        <td>@file.RelativePath</td>
                                        <td>@FormatFileSize(file.SizeInBytes)</td>
                                        <td>@file.LastChangedAt.ToString("dd.MM.yyyy HH:mm:ss")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <p class="text-muted small mt-3 mb-0">
                        Es werden die 10 größten Dateien im geprüften Projektordner angezeigt.
                    </p>
                </div>
            </div>
        }

        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Gefundene Dateien</h5>

                @if (scanResult.Files.Count == 0)
                {
                    <p class="text-muted mb-0">
                        Keine Dateien gefunden.
                    </p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Datei</th>
                                    <th>Endung</th>
                                    <th>Größe</th>
                                    <th>Geändert</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var file in scanResult.Files.Take(DisplayedFileLimit))
                                {
                                    <tr>
                                        <td>@file.RelativePath</td>
                                        <td>@file.Extension</td>
                                        <td>@FormatFileSize(file.SizeInBytes)</td>
                                        <td>@file.LastChangedAt.ToString("dd.MM.yyyy HH:mm:ss")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    @if (scanResult.Files.Count > DisplayedFileLimit)
                    {
                        <p class="text-muted small mt-3 mb-0">
                            Es werden erstmal nur die ersten @DisplayedFileLimit Dateien angezeigt.
                        </p>
                    }
                }
            </div>
        </div>
    }
</div>

@code {
    private const int DisplayedFileLimit = 50;
    private const int ComparisonFileLimit = 20;

    private string folderPath = string.Empty;
    private string? errorMessage;
    private string? infoMessage;
    private ProjectFolderScanResult? scanResult;
    private ProjectState? preparedProjectState;
    private IReadOnlyList<ProjectState> RememberedProjectStates => ProjectStateMemoryStore.ProjectStates;
    private ProjectStateComparisonResult? comparisonResult;
    private ProjectState? comparedOldProjectState;
    private ProjectState? comparedNewProjectState;

    private async Task PickFolderAsync()
    {
        errorMessage = null;
        infoMessage = null;
        preparedProjectState = null;
        comparisonResult = null;
        comparedOldProjectState = null;
        comparedNewProjectState = null;

        try
        {
            var result = await FolderPicker.PickAsync(CancellationToken.None);

            if (result.IsSuccessful && result.Folder is not null)
            {
                folderPath = result.Folder.Path;
                scanResult = null;
                infoMessage = "Ordner wurde ausgewählt.";
            }
            else if (result.Exception is not null)
            {
                errorMessage = $"Der Ordner konnte nicht ausgewählt werden: {result.Exception.Message}";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Der Ordner konnte nicht ausgewählt werden: {ex.Message}";
        }
    }

    private void ScanProjectFolder()
    {
        errorMessage = null;
        infoMessage = null;
        scanResult = null;
        preparedProjectState = null;
        comparisonResult = null;
        comparedOldProjectState = null;
        comparedNewProjectState = null;
        folderPath = folderPath.Trim();

        if (string.IsNullOrWhiteSpace(folderPath))
        {
            errorMessage = "Bitte geben Sie zuerst einen Projektordner an.";
            return;
        }

        if (!Directory.Exists(folderPath))
        {
            errorMessage = "Der angegebene Projektordner wurde nicht gefunden.";
            return;
        }

        try
        {
            scanResult = ProjectFolderScanner.ScanFolder(folderPath);

            preparedProjectState = ProjectStateBuilder.CreateFromScanResult(
                scanResult.ProjectName,
                scanResult);

            infoMessage = "Projektprüfung abgeschlossen. Projektstand wurde vorbereitet.";
        }
        catch (Exception ex)
        {
            errorMessage = $"Die Projektprüfung konnte nicht abgeschlossen werden: {ex.Message}";
        }
    }

    private void RememberPreparedProjectState()
    {
        if (preparedProjectState is null)
        {
            return;
        }

        bool wasRemembered = ProjectStateMemoryStore.Remember(preparedProjectState);

        if (!wasRemembered)
        {
            infoMessage = "Dieser Projektstand wurde bereits gemerkt.";
            return;
        }

        comparisonResult = null;
        comparedOldProjectState = null;
        comparedNewProjectState = null;
        errorMessage = null;
        infoMessage = "Projektstand wurde gemerkt.";
    }

    private bool IsPreparedProjectStateRemembered()
    {
        if (preparedProjectState is null)
        {
            return false;
        }

        return RememberedProjectStates
            .Any(projectState => projectState.Id == preparedProjectState.Id);
    }

    private void ClearRememberedProjectStates()
    {
        ProjectStateMemoryStore.Clear();

        comparisonResult = null;
        comparedOldProjectState = null;
        comparedNewProjectState = null;
        errorMessage = null;
        infoMessage = "Gemerkte Stände wurden geleert.";
    }

    private void CompareLatestProjectStates()
    {
        if (RememberedProjectStates.Count < 2)
        {
            return;
        }

        var newState = RememberedProjectStates[0];
        var oldState = RememberedProjectStates[1];

        if (!IsSameProjectFolder(oldState, newState))
        {
            comparisonResult = null;
            infoMessage = null;
            errorMessage = "Es können nur Projektstände aus demselben Projektordner verglichen werden.";
            return;
        }

        errorMessage = null;
        comparedOldProjectState = oldState;
        comparedNewProjectState = newState;
        comparisonResult = ProjectStateComparer.Compare(oldState, newState);
        infoMessage = "Vergleich wurde erstellt.";
    }

    private static bool IsSameProjectFolder(
        ProjectState oldState,
        ProjectState newState)
    {
        string oldPath = NormalizeFolderPath(oldState.RootPath);
        string newPath = NormalizeFolderPath(newState.RootPath);

        return string.Equals(
            oldPath,
            newPath,
            StringComparison.OrdinalIgnoreCase);
    }

    private static string NormalizeFolderPath(string folderPath)
    {
        return folderPath
            .Trim()
            .TrimEnd(Path.DirectorySeparatorChar, Path.AltDirectorySeparatorChar);
    }

    private int GetDisplayedFileCount()
    {
        if (scanResult is null)
        {
            return 0;
        }

        return Math.Min(scanResult.FileCount, DisplayedFileLimit);
    }

    private IEnumerable<FileTypeStat> GetFileTypeStats()
    {
        if (scanResult is null)
        {
            return Enumerable.Empty<FileTypeStat>();
        }

        return scanResult.Files
            .GroupBy(file => string.IsNullOrWhiteSpace(file.Extension)
                ? "Ohne Endung"
                : file.Extension.ToLowerInvariant())
            .Select(group => new FileTypeStat(
                group.Key,
                group.Count(),
                group.Sum(file => file.SizeInBytes)))
            .OrderByDescending(fileType => fileType.Count)
            .ThenBy(fileType => fileType.Extension)
            .Take(10);
    }

    private IEnumerable<ProjectFileEntry> GetLargestFiles()
    {
        if (scanResult is null)
        {
            return Enumerable.Empty<ProjectFileEntry>();
        }

        return scanResult.Files
            .OrderByDescending(file => file.SizeInBytes)
            .ThenBy(file => file.RelativePath)
            .Take(10);
    }

    private static string FormatScanDuration(TimeSpan duration)
    {
        if (duration.TotalMilliseconds < 1000)
        {
            return $"{duration.TotalMilliseconds:0} ms";
        }

        return $"{duration.TotalSeconds:0.0} Sekunden";
    }

    private static string FormatFileSize(long sizeInBytes)
    {
        if (sizeInBytes < 1024)
        {
            return $"{sizeInBytes} B";
        }

        double sizeInKb = sizeInBytes / 1024d;

        if (sizeInKb < 1024)
        {
            return $"{sizeInKb:0.0} KB";
        }

        double sizeInMb = sizeInKb / 1024d;

        if (sizeInMb < 1024)
        {
            return $"{sizeInMb:0.0} MB";
        }

        double sizeInGb = sizeInMb / 1024d;

        return $"{sizeInGb:0.0} GB";
    }

    private sealed record FileTypeStat(
        string Extension,
        int Count,
        long SizeInBytes);
}