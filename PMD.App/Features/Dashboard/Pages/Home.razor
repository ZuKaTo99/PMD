@page "/"

<PageTitle>PMD - Übersicht</PageTitle>

<div class="container-fluid pmd-dashboard">
    <div class="mb-4">
        <div class="text-muted small mb-1">PMD - Übersicht</div>
        <h1>Projektverwaltung</h1>
        <p class="text-muted mb-0">
            Einfache Übersicht für Projekte, Projektstände und Projektprüfungen.
        </p>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">Projekte</h5>
                    <p class="card-text">
                        Hier werden später deine Projekte gesammelt und übersichtlich angezeigt.
                    </p>
                    <a class="btn btn-primary" href="projektpruefung">
                        Öffnen
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">Projektstände</h5>
                    <p class="card-text">
                        Hier werden später gespeicherte Stände deiner Projekte angezeigt.
                    </p>
                    <button class="btn btn-primary" disabled>
                        Noch nicht verfügbar
                    </button>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">Projektprüfung</h5>
                    <p class="card-text">
                        Hier wird später ein Projektordner eingelesen und geprüft.
                    </p>
                    <button class="btn btn-primary" disabled>
                        Noch nicht verfügbar
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="alert alert-info mb-0">
        <strong>Aktueller Stand:</strong>
        Die Grundstruktur steht. Als nächstes wird die erste Projektprüfung vorbereitet.
    </div>
</div>
